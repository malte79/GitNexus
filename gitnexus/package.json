{
  "name": "codenexus",
  "version": "1.3.10",
  "description": "Headless local code intelligence for AI agents.",
  "author": "Abhigyan Patwari",
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/abhigyanpatwari/GitNexus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhigyanpatwari/GitNexus.git",
    "directory": "gitnexus"
  },
  "bugs": {
    "url": "https://github.com/abhigyanpatwari/GitNexus/issues"
  },
  "keywords": [
    "codenexus",
    "code-intelligence",
    "knowledge-graph",
    "ai-agent",
    "static-analysis",
    "codebase-indexing"
  ],
  "type": "module",
  "bin": {
    "codenexus": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "vendor"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "dev": "tsx watch src/cli/index.ts",
    "lint:docs": "node scripts/lint-docs.mjs",
    "check:docs-contracts": "node scripts/check-docs-contracts.mjs",
    "test": "vitest run test/unit",
    "test:integration": "sh scripts/run-integration-tests.sh",
    "test:all": "npm test && npm run test:integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "postinstall": "node scripts/patch-tree-sitter-swift.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "express": "^4.19.2",
    "glob": "^11.0.0",
    "graphology": "^0.25.4",
    "graphology-indices": "^0.17.0",
    "graphology-utils": "^2.3.0",
    "kuzu": "^0.11.3",
    "lru-cache": "^11.0.0",
    "mnemonist": "^0.39.0",
    "pandemonium": "^2.4.0",
    "smol-toml": "^1.4.1",
    "tree-sitter": "^0.21.0",
    "tree-sitter-c": "^0.21.0",
    "tree-sitter-c-sharp": "^0.21.0",
    "tree-sitter-cpp": "^0.22.0",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "uuid": "^13.0.0"
  },
  "optionalDependencies": {
    "tree-sitter-swift": "^0.6.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "markdownlint-cli2": "^0.18.1",
    "minimatch": "^10.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
